{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "rootDir": "./",
    "outDir": "dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
  },
  "include": [
    "*.mts",
    "*.ts",
    "agents/**/*.ts",
    "tools/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "client"
  ]
}